		{
			"name": "🔄 Full Workflow",
			"description": "Run these requests in order for a complete end-to-end test",
			"item": [
				{
					"name": "Step 1 — Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", ""]
						},
						"description": "Verify the server is running before starting the workflow."
					},
					"response": []
				},
				{
					"name": "Step 2 — Upload PDF",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.file_id) {",
									"    pm.collectionVariables.set('file_id', jsonData.file_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Select your PDF file"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/data/upload/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "data", "upload", "{{project_id}}"]
						},
						"description": "Upload a PDF file. The file_id will be auto-saved for the next steps."
