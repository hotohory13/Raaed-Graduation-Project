{
	"info": {
		"_postman_id": "raaed-graduation-project-api",
		"name": "Raaed Graduation Project API",
		"description": "Complete API collection for the Raaed RAG PDF Extraction & Retrieval Pipeline.\n\n## Workflow:\n1. **Health Check** — Verify the server is running\n2. **Upload PDF** — Upload a PDF file to a project\n3. **Process PDF** — Extract, chunk, and store content\n4. **Push to Vector DB** — Index chunks into ChromaDB/Qdrant\n5. **Search** — Semantic search with reranking\n6. **RAG Answer** — Get AI-generated answers from your documents\n\n## Setup:\n- Set `base_url` variable (default: http://localhost:5000)\n- Set `project_id` variable to your project name",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "project_id",
			"value": "testproject1",
			"type": "string"
		},
		{
			"key": "file_id",
			"value": "",
			"type": "string",
			"description": "Auto-set after upload"
		}
	],
	"item": [
		{
			"name": "🏥 Health & Info",
			"description": "Server health check and basic info endpoints",
			"item": [
				{
					"name": "Welcome / Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Server is running', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has app info', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('app_name');",
									"    pm.expect(jsonData).to.have.property('app_version');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", ""]
						},
						"description": "Returns the application name and version. Use this to verify the server is running."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"app_name\": \"Raaed\",\n    \"app_version\": \"0.1.0\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "📄 Data Management",
			"description": "File upload and PDF processing endpoints",
			"item": [
				{
					"name": "Upload PDF File",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('File uploaded successfully', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has file_id', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.signal).to.eql('file_upload_success');",
									"    pm.expect(jsonData).to.have.property('file_id');",
									"});",
									"",
									"// Auto-save file_id for later use",
									"var jsonData = pm.response.json();",
									"if (jsonData.file_id) {",
									"    pm.collectionVariables.set('file_id', jsonData.file_id);",
									"    console.log('Saved file_id: ' + jsonData.file_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Select a PDF file to upload"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/v1/data/upload/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "data", "upload", "{{project_id}}"]
						},
						"description": "Upload a PDF file to the specified project. The file will be stored and an asset record will be created in MongoDB.\n\n**Note:** Select a PDF file in the Body > form-data > file field."
					},
					"response": [
						{
							"name": "Upload Success",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"signal\": \"file_upload_success\",\n    \"file_id\": \"60f7b1234567890abcdef123\"\n}"
						},
						{
							"name": "Invalid File",
							"status": "Bad Request",
							"code": 400,
							"body": "{\n    \"signal\": \"file_type_not_supported\"\n}"
						}
					]
				},
				{
					"name": "Process All Project Files",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Processing completed', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Chunks were inserted', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.signal).to.eql('processing_success');",
									"    pm.expect(jsonData.inserted_chunks).to.be.above(0);",
									"    console.log('Inserted ' + jsonData.inserted_chunks + ' chunks from ' + jsonData.processed_files + ' files');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"chunk_size\": 100,\n    \"overlap_size\": 20,\n    \"do_reset\": 0\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/data/process/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "data", "process", "{{project_id}}"]
						},
						"description": "Process ALL uploaded PDF files in the project. Extracts text, chunks it semantically, and stores chunks in MongoDB.\n\n**Parameters:**\n- `chunk_size` (default: 100) — Max tokens per chunk\n- `overlap_size` (default: 20) — Token overlap between chunks\n- `do_reset` (0 or 1) — If 1, deletes existing chunks before processing"
					},
					"response": [
						{
							"name": "Processing Success",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"signal\": \"processing_success\",\n    \"inserted_chunks\": 42,\n    \"processed_files\": 1\n}"
						}
					]
				},
				{
					"name": "Process Specific File",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Processing completed', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Chunks were inserted', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.signal).to.eql('processing_success');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"file_id\": \"{{file_id}}\",\n    \"chunk_size\": 100,\n    \"overlap_size\": 20,\n    \"do_reset\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/data/process/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "data", "process", "{{project_id}}"]
						},
						"description": "Process a SPECIFIC uploaded file by its file_id. Uses the file_id auto-saved from the Upload request.\n\n**Parameters:**\n- `file_id` — The specific file to process (auto-filled from upload)\n- `chunk_size` (default: 100) — Max tokens per chunk\n- `overlap_size` (default: 20) — Token overlap between chunks\n- `do_reset` (0 or 1) — If 1, deletes existing chunks before processing"
					},
					"response": [
						{
							"name": "Processing Success",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"signal\": \"processing_success\",\n    \"inserted_chunks\": 28,\n    \"processed_files\": 1\n}"
						}
					]
				},
				{
					"name": "Process with Reset",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Processing with reset completed', function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.signal).to.eql('processing_success');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"chunk_size\": 150,\n    \"overlap_size\": 30,\n    \"do_reset\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/data/process/{{project_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "data", "process", "{{project_id}}"]
						},
						"description": "Re-process all files with reset enabled. Deletes all existing chunks first, then re-processes with custom chunk/overlap sizes.\n\nUseful for experimenting with different chunking parameters."
					},
					"response": []
				}
			]
		},
